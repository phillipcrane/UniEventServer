{
  "name": "functions",
  "description": "UniEvent backend services",
  "scripts": {
    "lint": "eslint .",
    "build": "tsc -p tsconfig.build.json",
    "watch": "tsc -p tsconfig.json --watch",
    "clean": "rimraf lib",
    "start": "npm run build && node lib/index.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "tool:ingest": "npm run build && node lib/tools/ingestTool.js",
    "tool:refresh": "npm run build && node lib/tools/refreshTool.js"
  },
  "engines": {
    "node": ">=22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/secret-manager": "^5.0.0",
    "axios": "^1.6.0",
    "express": "^5.1.0",
    "mime-types": "^2.1.35",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^20.19.25",
    "@types/node-fetch": "^2.6.13",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/ui": "^4.0.15",
    "c8": "^10.1.3",
    "eslint": "^8.15.0",
    "eslint-config-google": "^0.14.0",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "private": true
}
